aside.hidden.w-340px.flex-shrink-0(class="lg:block")
  div.sticky.top-24.space-y-8
    //- Profile Widget
    div.bg-white.rounded-2xl.p-6.shadow-sm.border.border-slate-100.text-center(class="dark:bg-slate-800 dark:border-slate-700")
      div.relative.w-24.h-24.mx-auto.rounded-full.overflow-hidden.mb-4.border-2.border-slate-50.ring-4.ring-indigo-50(class="dark:border-slate-700 dark:ring-indigo-900/30")
        img.w-full.h-full.object-cover(src="[##_image_##]" alt="Profile")
      h3.font-bold.text-lg.text-slate-800(class="dark:text-slate-100") [##_blogger_##]
      p.text-xs.text-indigo-600.font-medium.mb-3(class="dark:text-indigo-400") Frontend Developer
      p.text-sm.text-slate-500.mb-6.leading-relaxed(class="dark:text-slate-400")
        | [##_desc_##]
      div.flex.justify-center.gap-3
        a.w-8.h-8.rounded-full.bg-slate-50.flex.items-center.justify-center.text-slate-400.transition-colors(href="#" class="hover:text-slate-800 hover:bg-slate-100 dark:bg-slate-700 dark:hover:bg-slate-600 dark:text-slate-300 dark:hover:text-slate-100")
          i.fa-brands.fa-github
        a.w-8.h-8.rounded-full.bg-slate-50.flex.items-center.justify-center.text-slate-400.transition-colors(href="#" class="hover:text-blue-400 hover:bg-slate-100 dark:bg-slate-700 dark:hover:bg-slate-600 dark:text-slate-300 dark:hover:text-blue-400")
          i.fa-brands.fa-twitter
        a.w-8.h-8.rounded-full.bg-slate-50.flex.items-center.justify-center.text-slate-400.transition-colors(href="#" class="hover:text-red-500 hover:bg-slate-100 dark:bg-slate-700 dark:hover:bg-slate-600 dark:text-slate-300 dark:hover:text-red-400")
          i.fa-solid.fa-envelope

    //- Category Widget
    div.bg-white.rounded-2xl.p-6.shadow-sm.border.border-slate-100(class="dark:bg-slate-800 dark:border-slate-700")
      h4.font-bold.text-slate-800.mb-4.pb-2.border-b.border-slate-100.flex.items-center.gap-2(class="dark:text-slate-100 dark:border-slate-700")
        | 카테고리
      div.category-list.text-sm(class="dark:text-slate-300")
        | [##_category_list_##]

    //- Tags Widget
    div.bg-white.rounded-2xl.p-6.shadow-sm.border.border-slate-100(class="dark:bg-slate-800 dark:border-slate-700")
      h4.font-bold.text-slate-800.mb-4.pb-2.border-b.border-slate-100(class="dark:text-slate-100 dark:border-slate-700")
        | 인기 태그
      div.flex.flex-wrap.gap-2
        s_random_tags
          a.px-3.py-1.bg-slate-50.text-slate-600.text-xs.rounded-full.border.border-slate-100.transition-colors(href="[##_tag_link_##]" class="hover:bg-indigo-50 hover:text-indigo-600 dark:bg-slate-700 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-indigo-900/30 dark:hover:text-indigo-400")
            | # [##_tag_name_##]
