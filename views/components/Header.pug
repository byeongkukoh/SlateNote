header(class="sticky top-0 z-40 w-full bg-white/80 backdrop-blur-md border-b border-slate-200 shadow-sm transition-all dark:bg-slate-900/80 dark:border-slate-700")
  nav(class="max-w-[1440px] mx-auto px-4 h-16 flex items-center justify-between sm:px-6")
    .flex.items-center.gap-4
      include Header/Title
    .flex.items-center.gap-4
      s_search
        .hidden.items-center.gap-2(class="sm:flex")
          input#header-search-input.w-44.h-9.px-3.rounded-lg.border.border-slate-200.bg-white.text-sm.text-slate-700.outline-none.transition-colors(class="placeholder:text-slate-400 focus:border-indigo-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-200 dark:placeholder:text-slate-500 dark:focus:border-indigo-400" type="text" name="[##_search_name_##]" value="[##_search_text_##]" placeholder="검색어")
          button#header-search-submit.w-9.h-9.rounded-lg.border.border-slate-200.bg-white.text-slate-500.transition-colors(type="button" onclick="[##_search_onclick_submit_##]" class="hover:bg-slate-50 hover:text-slate-800 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400 dark:hover:bg-slate-700 dark:hover:text-slate-200")
            i.fa-solid.fa-search
      #header-owner-actions.hidden.items-center.gap-2(class="sm:flex")
        a.inline-flex.items-center.gap-1.rounded-full.border.border-slate-200.bg-white.px-3.text-xs.font-semibold.text-slate-600.transition-colors(href="[##_owner_url_##]/newpost/" class="py-1.5 hover:bg-slate-50 hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 dark:hover:text-indigo-400")
          i.fa-regular.fa-pen-to-square
          span 글쓰기
        a.inline-flex.items-center.gap-1.rounded-full.border.border-slate-200.bg-white.px-3.text-xs.font-semibold.text-slate-600.transition-colors(href="[##_owner_url_##]" class="py-1.5 hover:bg-slate-50 hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 dark:hover:text-indigo-400")
          i.fa-solid.fa-gear
          span 관리
      include Header/DarkModeToggle
      button#mobile-menu-toggle.p-2.text-slate-500.transition-colors(class="lg:hidden hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200")
        i.fa-solid.fa-bars
