s_article_rep
  s_permalink_article_rep
    .article-scroll-pane.animate-in.fade-in.slide-in-from-bottom-4.duration-500.bg-white.rounded-2xl.shadow-sm.border.border-slate-100.overflow-hidden(class="dark:bg-slate-800 dark:border-slate-700 lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto lg:overscroll-contain")

      //- Post Header
      .relative.w-full(class="h-52 sm:h-64 md:h-[340px]")
        s_article_rep_thumbnail
          img.w-full.h-full.object-cover(src="[##_article_rep_thumbnail_raw_url_##]" alt="[##_article_rep_title_##]")
        .absolute.inset-0(class="bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent")
        .absolute.bottom-0.left-0.w-full.text-white(class="p-6 sm:p-12")
          .flex.items-center.gap-2.mb-4.text-sm.font-medium.text-indigo-200
            a.px-3.py-1.backdrop-blur.rounded-full.transition-colors([##_article_rep_category_link_##] class="bg-white/20 hover:bg-white/30")
              | [##_article_rep_category_##]
          h1.text-3xl.font-bold.mb-6.leading-tight(class="sm:text-4xl lg:text-5xl")
            | [##_article_rep_title_##]
          .article-meta-row.flex.items-center.justify-between.gap-3.text-sm.text-slate-300.flex-wrap
            .flex.items-center.gap-4
              span.flex.items-center.gap-1
                i.fa-regular.fa-user
                | [##_article_rep_author_##]
              span.flex.items-center.gap-1
                i.fa-regular.fa-calendar
                | [##_article_rep_date_##]
              span.flex.items-center.gap-1
                i.fa-regular.fa-comment-dots
                s_rp_count
                  | [##_article_rep_rp_cnt_##]
            a.admin-edit-source.hidden(href="[##_s_ad_m_link_##]")
            a.admin-delete-source.hidden(onclick="[##_s_ad_d_onclick_##]" href="#")

      .p-6(class="sm:p-12")
        //- Post Content
        .article-content.tt_article_useless_p_margin
          | [##_article_rep_desc_##]

        //- Tags
        s_tag_label
          .mt-16.flex.flex-wrap.gap-2
            | [##_tag_label_rep_##]

        //- Navigation to List
        .mt-12.flex.justify-center
          button.flex.items-center.gap-2.px-8.py-4.bg-white.border.border-slate-200.text-slate-600.rounded-full.font-bold.transition-colors.shadow-sm(onclick="location.href='/'" class="hover:bg-slate-50 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-700")
            i.fa-solid.fa-arrow-left
            | 목록으로 돌아가기

      //- Floating TOC (chat-style FAB)
      button#toc-toggle(type="button" aria-label="목차 열기" aria-controls="toc-container" aria-expanded="false" class="fixed right-4 bottom-4 sm:right-6 sm:bottom-6 z-50 w-12 h-12 rounded-full bg-indigo-600 text-white shadow-lg flex items-center justify-center transition hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400")
        i.fa-solid.fa-list-ul

      aside#toc-container(class="fixed right-4 bottom-20 sm:right-6 sm:bottom-24 z-50 w-72 sm:w-80 max-w-[92vw] max-h-[62vh] bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-2xl p-4 opacity-0 translate-y-2 pointer-events-none transition-all duration-200")
        .flex.items-center.justify-between.mb-3
          .text-xs.font-bold.text-slate-500.uppercase.tracking-widest(class="dark:text-slate-400") TOC
          button#toc-close(type="button" aria-label="목차 닫기" class="w-7 h-7 rounded-full text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-700")
            i.fa-solid.fa-xmark
        nav#toc.text-xs.flex.flex-col.overflow-y-auto(class="space-y-1.5 max-h-[48vh]")
